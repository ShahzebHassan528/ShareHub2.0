# ============================================================
# ShareHub 2.0 — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Database (MySQL) -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Leave empty for XAMPP with no root password:
DB_PASSWORD=
DB_NAME=marketplace_db

# ----- Server -----
NODE_ENV=development        # development | production
PORT=5000
USE_SEQUELIZE=true

# ----- Authentication -----
# Change this to a long random string in production!
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ----- Redis (optional — used for rate-limiting cache) -----
REDIS_HOST=localhost
REDIS_PORT=6379
